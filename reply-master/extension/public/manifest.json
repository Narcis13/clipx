{
  "manifest_version": 3,
  "name": "Reply Master",
  "version": "0.1.0",
  "description": "Auto-generate thoughtful replies on X via local AI",
  "permissions": ["activeTab", "storage", "scripting", "tabs", "clipboardWrite"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "http://localhost:8787/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://x.com/i/grok*"],
      "js": ["grok.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Reply Master"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
